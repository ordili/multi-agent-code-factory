# =============================================================================
# 运行环境配置 — 复制为 `.env`，勿提交 Git
# CLI 与 pytest 启动时自动加载；shell 已设变量优先于本文件。
#
# Stub 模式（默认）无需 LLM 配置；只有 `--live` 需要下面「LLM」一节。
# 语言栈用 CLI `--profile`，不在此配置（见 profiles/*.yaml）。
# 回路默认见 config/autonomy_policy.yaml；一般不必改 FACTORY_MAX_*。
# 详见 docs/design/pipeline/profiles.md §0
# =============================================================================

# --- LLM（--live）---
# 未设置时代码默认 deepseek + deepseek-chat；下面为云 API 最小配置。
FACTORY_LLM_PROVIDER=deepseek
FACTORY_LLM_MODEL=deepseek-chat
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Ollama（与上面二选一：改 provider/model，并注释掉不需要的云 Key）
# FACTORY_LLM_PROVIDER=ollama
# FACTORY_LLM_MODEL=qwen3.5:9b
# OLLAMA_BASE_URL=http://127.0.0.1:11434
# OLLAMA_NUM_CTX=8192
# OLLAMA_NUM_PREDICT=4096
# OLLAMA_NUM_GPU=
# OLLAMA_REASONING=false

# --- 工厂策略覆盖（可选；默认 config/autonomy_policy.yaml）---
# FACTORY_MAX_IMPL_RETRIES=3
# FACTORY_MAX_DESIGN_REVISIONS=2
# FACTORY_MAX_SPEC_REVISIONS=1
# FACTORY_MAX_HITL_ROUNDS=5
# FACTORY_ON_LIMIT_EXCEEDED=fail
# FACTORY_MAX_LLM_CALLS=
# FACTORY_MAX_TOKENS=

# --- Profile 路径占位（仅当 YAML 使用 ${FACTORY_CODE_ROOT}/... 时需要）---
# FACTORY_CODE_ROOT=D:/code/generated

# --- 日志（CLI 默认 INFO；也可用 --log-level）---
# FACTORY_LOG_LEVEL=INFO

# --- 可观测性（LangChain 标准变量，可选）---
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=multi-agent-code-factory
