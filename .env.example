# =============================================================================
# 运行环境配置（本机 / CI 密钥）— 复制为 `.env`，勿提交 Git
# CLI 与 pytest 启动时自动加载；shell 里已设的变量优先于本文件。
#
# 职责边界：
#   .env     → 密钥、本机差异、可选工厂/LLM 覆盖（见下）
#   Profile  → 语言、toolchain、validation、code_root 路径约定（profiles/*.yaml）
#   config/  → 团队共享的回路默认（autonomy_policy.yaml）
# 详见 docs/design/pipeline/profiles.md §0
# =============================================================================

# --- LLM（--live 必填；勿写入 Profile YAML）---
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# 覆盖模型（可选；优先于 DEEPSEEK_MODEL）
# FACTORY_CHAT_MODEL=openai:deepseek-reasoner
# FACTORY_LLM_PROVIDER=openai

# --- 工厂策略覆盖（可选；团队默认见 config/autonomy_policy.yaml）---
# FACTORY_MAX_IMPL_RETRIES=3
# FACTORY_MAX_DESIGN_REVISIONS=2
# FACTORY_MAX_SPEC_REVISIONS=1
# FACTORY_MAX_HITL_ROUNDS=5
# FACTORY_ON_LIMIT_EXCEEDED=fail
# FACTORY_MAX_LLM_CALLS=
# FACTORY_MAX_TOKENS=

# --- Profile 路径占位（仅当 YAML 使用 ${FACTORY_CODE_ROOT}/... 时需要）---
# 若 Profile 已写 ../generated/<id>，无需配置此项
# FACTORY_CODE_ROOT=D:/code/generated

# --- 可观测性（LangChain 标准变量，可选）---
# LANGSMITH_API_KEY=
# LANGSMITH_TRACING=true
# LANGSMITH_PROJECT=multi-agent-code-factory
